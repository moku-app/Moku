{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "http-scope",
  "description": "HTTP fetch scope",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*/*" },
        { "url": "https://*:*/*" },
        { "url": "http://*/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
