{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Moku",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "java",              "args": true },
        { "name": "javaw",             "args": true },
        { "name": "suwayomi-server",   "args": true },
        { "name": "tachidesk-server",  "args": true }
      ]
    }
  ]
}
